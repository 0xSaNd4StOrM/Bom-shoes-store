# Copy to supabase/functions/.env for local `supabase functions serve`.
# In production these are set via `supabase secrets set` (or the dashboard),
# never committed.

# Kashier (test/demo credentials only until this store goes live -- see
# https://developers.kashier.io/). Used server-side only: never ship these
# to the frontend.
KASHIER_MERCHANT_ID=MID-XXXX-XXX
KASHIER_API_KEY=your-kashier-payment-api-key
# Optional. "test" (default) or "live" -- switches between
# test-iframe.kashier.io and iframe.kashier.io in create-order.
KASHIER_MODE=test

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_your_resend_api_key
# Must be an address on a domain you've verified in Resend. The shared
# resend.dev sandbox domain only delivers to the Resend account owner's own
# inbox, so it will silently fail to reach real customers.
RESEND_FROM_EMAIL=orders@your-verified-domain.com

# Auto-injected by Supabase in production edge functions -- only needed here
# for local `supabase functions serve` testing.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
