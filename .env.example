# Copy to .env.local (or .env) and fill in your Supabase project's values.
# These match the fallback values already hardcoded in src/lib/supabase.ts --
# set real ones here once you have a project so nothing depends on that
# fallback.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Edge function secret (set via `supabase secrets set`, not read by Vite):
# the store's real origin(s), comma-separated. Used by create-order to
# validate the Kashier merchant redirect instead of trusting the Origin header.
SITE_URL=https://your-store-domain.com
